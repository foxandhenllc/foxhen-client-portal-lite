{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": ".tmp-tests",
    "noEmit": false
  },
  "include": ["src/data/**/*.ts", "src/lib/**/*.ts", "src/exporters/**/*.ts", "tests/**/*.ts"]
}
