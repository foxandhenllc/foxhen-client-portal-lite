{
  "name": "foxhen-client-portal-lite",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run test:smoke",
    "test:smoke": "rm -rf .tmp-tests && tsc -p tsconfig.test.json && node .tmp-tests/tests/exporters.smoke.test.js && node .tmp-tests/tests/workspaceStorage.smoke.test.js",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "5.4.14",
    "typescript": "5.7.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=20"
  },
  "description": "Use this repo to create a static client workspace for milestones, approvals, decisions, file requests, closeout checks, and status exports.",
  "keywords": [
    "approval",
    "client",
    "dashboard",
    "fox-and-hen",
    "handoff",
    "milestone",
    "portal",
    "small-business",
    "starter",
    "static",
    "template",
    "workflow-tools",
    "workspace"
  ],
  "license": "MIT"
}
